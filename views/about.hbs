{{>menu id="About"}}

<section class="ui center aligned middle aligned segment">
    <h2>About the Playlist App</h2>
    <h3>
        Information about the playlist app
    </h3>
    <div class="ui centered card">
      {{#each employees}}
  <div class="image">
    <img src="{{image}}">
  </div>
  <div class="content">
    <a class="header">{{fullname}} </a>
    <div class="meta">
      <span class="date">Joined in {{joined}} </span>
    </div>
    <div class="description">
       {{name}} is an {{job}}  living in  {{city}}.
    </div>
  </div>
  <div class="extra content">
    <a>
      <i class="user icon"></i>
        contacts
        {{mates}}
    </a>
  </div>
  {{/each}}
</div>
</section>